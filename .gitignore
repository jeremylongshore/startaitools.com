# Hugo generated files
public/
resources/_gen/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~startaitools/

# Generated reports
link-check-output.log
link-check-report.txt
*.log
tools/

# Derived methodology index (regenerated from JSONL source-of-truth)
.claude/skills/*/methodology/index.db

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.crosspost-queue.json

# Blog pipeline runtime state (WS1 inverted-commit-path). All derived/transient.
# NOTE: gitignore has no trailing inline comments — patterns must stand alone.
# .blog-staging/ = readiness sentinels the skill writes (consumed by blog-land.sh)
# .blog-quarantine/ = stranded artifacts moved aside when preconditions fail
# .blog-syndication-ledger.json = per-post did-he-post record (packet + rollup)
.blog-staging/
.blog-quarantine/
.blog-syndication-ledger.json

# Python bytecode (blog pipeline skill scripts)
__pycache__/
*.pyc

# .next-topics.jsonl = analytics-driven topic queue (Thread D Phase 1); regenerated by next-topics-refresh.sh, consumed by writers
.next-topics.jsonl
.next-topics.staging.jsonl
